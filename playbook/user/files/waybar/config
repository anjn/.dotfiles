{
  "layer": "top",
  "position": "top",
  "height": 29,

  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],

  "modules-center": [
    "sway/window"
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "clock",
    "tray"
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true
  },

  "sway/window": {
    "max-length": 80
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "VOL muted",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },

  "network": {
    "format-wifi": "Wi-Fi {essid} {signalStrength}%",
    "format-ethernet": "LAN",
    "format-disconnected": "offline"
  },

  "clock": {
    "format": "{:%Y-%m-%d %H:%M}"
  },

  "tray": {
    "spacing": 10
  }
}
